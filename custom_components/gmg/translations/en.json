{
  "config": {
    "step": {
      "user": {
        "title": "Set up a Green Mountain Grill",
        "description": "Add a grill by scanning your LAN or entering its address manually.",
        "menu_options": {
          "scan": "Scan my network",
          "manual": "Enter address manually"
        }
      },
      "scan": {
        "title": "Discovered grills",
        "description": "Pick the grill to add.",
        "data": {
          "selected_host": "Grill"
        }
      },
      "manual": {
        "title": "Connect to your grill",
        "description": "Find the grill's IP in your router admin panel.",
        "data": {
          "host": "IP address or hostname",
          "port": "Port"
        },
        "data_description": {
          "host": "The local LAN address of the grill's WiFi module.",
          "port": "UDP port for the grill protocol (default 8080)."
        }
      },
      "discovery_confirm": {
        "title": "Add {name}?",
        "description": "Found a {model} at {host}. Do you want to add it?"
      },
      "reconfigure": {
        "title": "Reconfigure grill",
        "data": {
          "host": "IP address or hostname",
          "port": "Port"
        }
      }
    },
    "error": {
      "cannot_connect": "Could not reach the grill at that address.",
      "invalid_response": "The grill responded with unexpected data.",
      "unknown": "Unexpected error. Check the logs."
    },
    "abort": {
      "already_configured": "This grill is already configured.",
      "no_devices_found": "No grills found on the local network. Make sure the grill is on, connected to WiFi (not Server Mode), and on the same VLAN.",
      "server_mode_enabled": "The grill is in Server Mode and is not reachable locally. Disable Server Mode in the GMG app and try again.",
      "wrong_device": "The address points to a different grill than this entry.",
      "cannot_connect": "Could not reach the grill at that address.",
      "reconfigure_successful": "Reconfigured successfully."
    }
  },
  "options": {
    "step": {
      "init": {
        "data": {
          "scan_interval": "Polling interval (seconds)"
