{
  "config": {
    "step": {
      "user": {
        "title": "Set up a Green Mountain Grill",
        "description": "Add a grill by scanning your LAN or entering its address manually.",
        "menu_options": {
          "scan": "Scan my network",
          "manual": "Enter address manually"
        }
